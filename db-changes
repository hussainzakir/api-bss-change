SELECT DISTINCT
       CO.COMPANY AS CLIENT_CODE,
       CO.DESCR AS CLIENT_DESCRIPTION,
       B.T2_OE_QUARTER,
       B.T2_PLAN_DT_START,
       B.T2_COMP_LIVE_DT
  FROM SYSADM.PS_COMPANY_TBL CO
  JOIN SYSADM.PS_T2_CLIENTOPTION B
    ON CO.COMPANY = B.COMPANY
 WHERE B.T2_COMP_TERM_DT IS NULL
   AND (
         TO_CHAR(B.T2_PLAN_DT_START, 'YYYY') = '2027'
         OR (
              B.T2_PLAN_DT_START IS NULL
              AND TO_CHAR(B.T2_COMP_LIVE_DT, 'YYYY') = '2027'
            )
       )
   AND NOT EXISTS (
         SELECT 1
           FROM SYSADM.PS_T2_PAYROLL_HDR HDR
          WHERE HDR.COMPANY = CO.COMPANY
            AND HDR.SEQUENCE_NBR_6 > 0
       )
   AND CO.EFFDT = (
         SELECT MAX(C1.EFFDT)
           FROM SYSADM.PS_COMPANY_TBL C1
          WHERE C1.COMPANY = CO.COMPANY
            AND C1.EFFDT <= TRUNC(SYSDATE)
       )
 ORDER BY CO.COMPANY;
