SELECT owner, object_name, object_type
FROM all_objects
WHERE object_name IN (
  'PS_COMPANY_TBL',
  'PS_T2_CLIENTOPTION',
  'PS_T2_PAYROLL_HDR'
)
ORDER BY owner, object_name;

SELECT owner, synonym_name, table_owner, table_name
FROM all_synonyms
WHERE synonym_name IN (
  'PS_COMPANY_TBL',
  'PS_T2_CLIENTOPTION',
  'PS_T2_PAYROLL_HDR'
)
ORDER BY owner, synonym_name;

SELECT DISTINCT CO.COMPANY AS CLIENT_CODE,
       CO.DESCR AS CLIENT_DESCRIPTION
  FROM PS_COMPANY_TBL@HRDB_SEEKER CO
 INNER JOIN PS_T2_CLIENTOPTION@HRDB_SEEKER B
    ON CO.COMPANY = B.COMPANY
 WHERE B.T2_COMP_TERM_DT IS NULL
   AND NOT EXISTS (
       SELECT 1
         FROM PS_T2_PAYROLL_HDR@HRDB_SEEKER HDR
        WHERE HDR.COMPANY = CO.COMPANY
          AND HDR.SEQUENCE_NBR_6 > 0
   )
   AND CO.EFFDT = (
       SELECT MAX(EFFDT)
         FROM PS_COMPANY_TBL@HRDB_SEEKER C1
        WHERE C1.COMPANY = CO.COMPANY
          AND C1.EFFDT <= TRUNC(SYSDATE)
   )
ORDER BY CO.COMPANY;
