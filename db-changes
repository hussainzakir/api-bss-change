SELECT DISTINCT 
    CO.COMPANY AS CLIENT_CODE,
    CO.DESCR AS CLIENT_DESCRIPTION,
    B.PF_CLIENT,
    B.T2_OE_QUARTER AS QUARTER,
    B.T2_PLAN_DT_START AS PLAN_START_DATE,
    R.BEN_EXCHNG,
    RPY.ID AS REALM_PLAN_YEAR_ID,
    RPY.PLAN_YEAR_START,
    RPY.PLAN_YEAR_END
FROM PS_COMPANY_TBL CO
INNER JOIN PS_T2_CLIENTOPTION B ON CO.COMPANY = B.COMPANY
INNER JOIN XBSS_REALM_PLAN_YEAR RPY ON B.T2_PLAN_DT_START BETWEEN RPY.PLAN_YEAR_START AND RPY.PLAN_YEAR_END
INNER JOIN XBSS_REALM R ON R.ID = RPY.REALM_ID
WHERE B.T2_COMP_TERM_DT IS NULL  
  AND B.T2_OE_QUARTER IS NOT NULL
  AND B.T2_PLAN_DT_START IS NOT NULL
  AND NOT EXISTS (
      SELECT 'X'
        FROM PS_T2_PAYROLL_HDR HDR
       WHERE HDR.COMPANY = B.COMPANY
         AND HDR.SEQUENCE_NBR_6 > 0
  )
  AND CO.EFFDT = (
      SELECT MAX(EFFDT)
        FROM PS_COMPANY_TBL C1
       WHERE C1.COMPANY = CO.COMPANY
         AND C1.EFFDT <= TRUNC(SYSDATE)
  )
ORDER BY CO.COMPANY;



SELECT 
    CO.COMPANY AS CLIENT_CODE,
    CO.DESCR AS CLIENT_DESCRIPTION,
    B.T2_OE_QUARTER AS QUARTER,
    B.T2_PLAN_DT_START AS PLAN_START_DATE,
    B.T2_COMP_LIVE_DT AS LIVE_DATE,
    B.PF_CLIENT,
    CASE 
        WHEN B.T2_OE_QUARTER IS NULL THEN 'MISSING_QUARTER'
        WHEN B.T2_PLAN_DT_START IS NULL THEN 'MISSING_PLAN_START_DATE'
        WHEN NOT EXISTS (
            SELECT 1 FROM XBSS_REALM_PLAN_YEAR RPY 
            WHERE B.T2_PLAN_DT_START BETWEEN RPY.PLAN_YEAR_START AND RPY.PLAN_YEAR_END
        ) THEN 'NO_REALM_PLAN_YEAR_FOR_DATE'
        ELSE 'OK'
    END AS ISSUE
FROM PS_COMPANY_TBL CO
INNER JOIN PS_T2_CLIENTOPTION B ON CO.COMPANY = B.COMPANY
WHERE B.T2_COMP_TERM_DT IS NULL  
  AND NOT EXISTS (
      SELECT 'X'
        FROM PS_T2_PAYROLL_HDR HDR
       WHERE HDR.COMPANY = B.COMPANY
         AND HDR.SEQUENCE_NBR_6 > 0
  )
  AND CO.EFFDT = (
      SELECT MAX(EFFDT)
        FROM PS_COMPANY_TBL C1
       WHERE C1.COMPANY = CO.COMPANY
         AND C1.EFFDT <= TRUNC(SYSDATE)
  )
ORDER BY CO.COMPANY;
