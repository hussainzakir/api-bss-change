SELECT DISTINCT
       CO.COMPANY AS CLIENT_CODE,
       CO.DESCR AS CLIENT_DESCRIPTION,
       B.PF_CLIENT,
       B.T2_OE_QUARTER,
       B.T2_PLAN_DT_START,
       RPY.PLAN_YEAR_START,
       RPY.PLAN_YEAR_END
FROM PS_COMPANY_TBL CO
JOIN PS_T2_CLIENTOPTION B
  ON CO.COMPANY = B.COMPANY
JOIN XBSS_REALM_PLAN_YEAR RPY
  ON RPY.OE_QUARTER = B.T2_OE_QUARTER
WHERE B.T2_COMP_TERM_DT IS NULL
  AND EXTRACT(YEAR FROM RPY.PLAN_YEAR_START) = 2027
  AND NOT EXISTS (
        SELECT 1
          FROM PS_T2_PAYROLL_HDR HDR
         WHERE HDR.COMPANY = CO.COMPANY
           AND HDR.SEQUENCE_NBR_6 > 0
      )
  AND CO.EFFDT = (
        SELECT MAX(C1.EFFDT)
          FROM PS_COMPANY_TBL C1
         WHERE C1.COMPANY = CO.COMPANY
           AND C1.EFFDT <= TRUNC(SYSDATE)
      )
ORDER BY CO.COMPANY;

  AND B.T2_OE_QUARTER LIKE '2027%'
