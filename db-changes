SELECT 
    CO.COMPANY AS CLIENT_CODE,
    CO.DESCR AS CLIENT_DESCRIPTION,
    B.T2_OE_QUARTER AS QUARTER,
    B.T2_PLAN_DT_START AS PLAN_START_DATE,
    B.T2_COMP_LIVE_DT AS LIVE_DATE,
    B.PF_CLIENT,
    CASE 
        WHEN B.T2_OE_QUARTER IS NULL THEN 'MISSING QUARTER'
        WHEN B.T2_PLAN_DT_START IS NULL THEN 'MISSING PLAN_START_DATE'
        WHEN NOT EXISTS (
            SELECT 1 FROM XBSS_REALM_TYPE RT 
            WHERE RT.QUARTER = B.T2_OE_QUARTER
        ) THEN 'NO REALM_TYPE FOR QUARTER'
        ELSE 'OK'
    END AS ISSUE
FROM PS_COMPANY_TBL CO
INNER JOIN PS_T2_CLIENTOPTION B ON CO.COMPANY = B.COMPANY
LEFT JOIN XBSS_REALM_TYPE RT ON RT.QUARTER = B.T2_OE_QUARTER
LEFT JOIN XBSS_REALM_PLAN_YEAR RPY ON RPY.REALM_ID = RT.ID
WHERE B.T2_COMP_TERM_DT IS NULL  
  AND NOT EXISTS (
      SELECT 'X'
        FROM PS_T2_PAYROLL_HDR HDR
       WHERE HDR.COMPANY = B.COMPANY
         AND HDR.SEQUENCE_NBR_6 > 0
  )
  AND CO.EFFDT = (
      SELECT MAX(EFFDT)
        FROM PS_COMPANY_TBL C1
       WHERE C1.COMPANY = CO.COMPANY
         AND C1.EFFDT <= TRUNC(SYSDATE)
  )
ORDER BY CO.COMPANY;
