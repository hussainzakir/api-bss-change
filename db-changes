SELECT DISTINCT CO.COMPANY AS CLIENT_CODE,
                 CO.DESCR AS CLIENT_DESCRIPTION
  FROM PS_COMPANY_TBL CO
 WHERE CO.COMPANY IN (
       SELECT B.COMPANY
         FROM PS_T2_CLIENTOPTION B
        WHERE B.T2_COMP_TERM_DT IS NULL  
          AND NOT EXISTS (
              SELECT 'X'
                FROM PS_T2_PAYROLL_HDR HDR
               WHERE HDR.COMPANY = B.COMPANY
                 AND HDR.SEQUENCE_NBR_6 > 0 )
       )
   AND CO.EFFDT = (
       SELECT MAX( EFFDT )
         FROM PS_COMPANY_TBL C1
        WHERE C1.COMPANY = CO.COMPANY
          AND C1.EFFDT <= TRUNC(SYSDATE) )
ORDER BY CO.COMPANY;

SELECT DISTINCT 
       CO.COMPANY AS CLIENT_CODE,
       CO.DESCR AS CLIENT_DESCRIPTION,
       B.PF_CLIENT,
       B.T2_OE_QUARTER AS QUARTER,
       B.EFFDT AS EFFECTIVE_DATE,
       CASE 
           WHEN MAX(HDR.SEQUENCE_NBR_6) IS NULL THEN 'No Payroll'
           ELSE 'Payroll Processed'
       END AS PAYROLL_STATUS
  FROM PS_COMPANY_TBL CO
  INNER JOIN PS_T2_CLIENTOPTION B ON CO.COMPANY = B.COMPANY
  LEFT JOIN PS_T2_PAYROLL_HDR HDR ON HDR.COMPANY = B.COMPANY
 WHERE B.T2_COMP_TERM_DT IS NULL  
   AND NOT EXISTS (
       SELECT 'X'
         FROM PS_T2_PAYROLL_HDR HDR2
        WHERE HDR2.COMPANY = B.COMPANY
          AND HDR2.SEQUENCE_NBR_6 > 0 )
   AND CO.EFFDT = (
       SELECT MAX( EFFDT )
         FROM PS_COMPANY_TBL C1
        WHERE C1.COMPANY = CO.COMPANY
          AND C1.EFFDT <= TRUNC(SYSDATE) )
GROUP BY CO.COMPANY, CO.DESCR, B.PF_CLIENT, B.T2_OE_QUARTER, B.EFFDT
ORDER BY CO.COMPANY;
