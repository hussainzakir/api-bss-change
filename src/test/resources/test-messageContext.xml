	<bean id="leavePlanXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg
			value="com.trinet.messaging.psft.mapper.LeavePlanXMLFormation" />
	</bean>
	
	<bean id="businessTitleXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg
			value="com.trinet.messaging.psft.mapper.BusinessTitleXMLFormation" />
	</bean>
	
	<bean id="workersCompXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg
			value="com.trinet.messaging.psft.mapper.WorkersCompXMLFormation" />
	</bean>
	
	<bean id="employeeTransferSOXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg
			value="com.trinet.messaging.crm.mapper.EmployeeTransferSOXMLFormation" />
	</bean>
	
	<bean id="leaveRequestSOXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg
			value="com.trinet.messaging.crm.mapper.LeaveRequestSOXMLFormation" />
	</bean>
	
	<bean id="employeeRoleXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg 
			value="com.trinet.messaging.fragomen.mapper.EmployeeRoleXMLFormation"/>
	</bean>
	
	<bean id="jobUsrFldsXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg 
			value="com.trinet.messaging.psft.mapper.OptionalGroupXMLFormation"/>
	</bean>
	
	<bean id="ldapRoleXMLFormation" class="org.mockito.Mockito"
		factory-method="mock">
		<constructor-arg 
			value="com.trinet.messaging.platform.mapper.LdapRoleXMLFormation"/>
	</bean>

        <bean id="addlPayXMLFormation" class="org.mockito.Mockito"
                factory-method="mock">
                <constructor-arg
                        value="com.trinet.messaging.psft.mapper.AddlPayXMLFormation"/>
        </bean>
	
</beans>
